# Database
POSTGRES_USER=vimonitor
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vimonitor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (broker for ARQ + rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API
# Bootstrap API key for the single tenant. Change before deploy.
BOOTSTRAP_API_KEY=change_me_api_key
BOOTSTRAP_TENANT_NAME=default

# Monitoring domain
TARGET_CITY=Москва
# City id / region cookie value used by vseinstrumenti.ru (fill after fetcher reverse-engineering).
TARGET_CITY_ID=

# Scheduling
DEFAULT_CHECK_INTERVAL_SECONDS=21600
SCHEDULER_TICK_SECONDS=60
SCHEDULE_JITTER_SECONDS=300

# Fetcher
# httpx: plain HTTP (blocked by ServicePipe). playwright: real browser (needs clean/residential IP).
FETCHER_BACKEND=httpx
FETCH_TIMEOUT_SECONDS=20
FETCH_MAX_RETRIES=3
FETCH_MIN_DELAY_SECONDS=1.0
FETCH_MAX_DELAY_SECONDS=3.0
# Global polite rate limit (requests per second across all workers)
GLOBAL_RATE_LIMIT_RPS=2.0

# Optional proxy / external anti-bot service (used when FETCHER_BACKEND != httpx)
PROXY_URL=
SCRAPING_SERVICE_URL=
SCRAPING_SERVICE_KEY=

# Cookie-harvest (FETCHER_BACKEND=httpx): reuse ServicePipe cookies from a real browser.
# SESSION_COOKIE: raw Cookie header. COOKIE_FILE: path re-read each fetch (hot-swap).
# HARVEST_USER_AGENT: must match the browser the cookie came from (UA+IP bound).
SESSION_COOKIE=
COOKIE_FILE=
HARVEST_USER_AGENT=

# Playwright backend (FETCHER_BACKEND=playwright)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAV_TIMEOUT_MS=45000
PLAYWRIGHT_WAIT_MS=4000
PLAYWRIGHT_MAX_CONCURRENCY=3

LOG_LEVEL=INFO
